        LocalDateTime videoStartDate = null;
        LocalDateTime videoEndDate = LocalDateTime.now();
        
        if (parameters.containsFields("date-time")) {
            Value dateTimeValue = parameters.getFieldsOrThrow("date-time");
            Struct dateTimeStruct = null;
            
            if (dateTimeValue.hasListValue() && dateTimeValue.getListValue().getValuesCount() > 0) {
                Value firstValue = dateTimeValue.getListValue().getValues(0);
                if (firstValue.hasStructValue()) {
                    dateTimeStruct = firstValue.getStructValue();
                }
            } else if (dateTimeValue.hasStructValue()) {
                dateTimeStruct = dateTimeValue.getStructValue();
            }
            
            if (dateTimeStruct != null) {
                String startDateStr = dateTimeStruct.getFieldsOrDefault("startDate", Value.newBuilder().setStringValue("").build()).getStringValue();
                String endDateStr = dateTimeStruct.getFieldsOrDefault("endDate", Value.newBuilder().setStringValue("").build()).getStringValue();
                
                log.info("date-time 파라미터 파싱: startDate={}, endDate={}", startDateStr, endDateStr);
                
                if (!startDateStr.isEmpty() && !endDateStr.isEmpty()) {
                    videoStartDate = parseDialogflowDateTime(startDateStr);
                    videoEndDate = parseDialogflowDateTime(endDateStr);
                    
                    if (videoStartDate != null && videoEndDate != null) {
                        videoEndDate = videoEndDate.withHour(23).withMinute(59).withSecond(59);
                    }
                }
            }
        } else if (!videoDate.isEmpty()) {
            LocalDateTime[] dateRange = parseSingleDate(videoDate);
            if (dateRange != null) {
                if (!isValidDateRange(dateRange[0], dateRange[1])) {
                    return createErrorResponse("날짜 범위가 유효하지 않습니다. 시작일은 종료일보다 이전이어야 합니다.");
                }
                videoStartDate = dateRange[0];
                videoEndDate = dateRange[1];
            }
        }
        
        if (videoStartDate == null || videoEndDate == null) {
            videoEndDate = LocalDateTime.now();
            videoStartDate = videoEndDate.minusDays(7);
        }
        
        RecentVideosResponse recentVideos = videoService.getRecentVideosForChatbot(userId, videoStartDate, videoEndDate, 10);
        
        StringBuilder videosBuilder = new StringBuilder();
        videosBuilder.append("🎥 최근 녹화 영상\n\n");
        videosBuilder.append("총 ").append(recentVideos.getTotalCount()).append("개의 영상을 찾았습니다:\n\n");
        
        if (recentVideos.getVideoList().isEmpty()) {
            videosBuilder.append("해당 기간에 녹화된 영상이 없습니다.");
        } else {
            for (RecentVideosResponse.VideoInfo video : recentVideos.getVideoList()) {
                videosBuilder.append("• ").append(video.getCctvName())
                        .append(" - ");
                if (video.getAnomalyTime() != null) {
                    videosBuilder.append(video.getAnomalyTime().toLocalDate()).append(" ");
                    if (video.getAnomalyTime().toLocalTime() != null) {
                        String timeStr = video.getAnomalyTime().toLocalTime().toString();
                        if (timeStr.length() >= 5) {
                            videosBuilder.append(timeStr.substring(0, 5));
                        }
                    }
                }
                videosBuilder.append(" (").append(video.getDuration()).append("초)")
                        .append(" - ").append(video.getStatus())
                        .append("\n\n");
            }
        }
        
        ChatbotResponse response = new ChatbotResponse();
        response.setReply(videosBuilder.toString());
        return response;
    }


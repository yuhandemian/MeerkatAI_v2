    public ChatbotResponse processMessage(String message) {
        try {
            log.info("챗봇 메시지 처리 시작: {}", message);
            
            QueryResult queryResult = dialogflowService.detectIntent(message);
            String intentDisplayName = queryResult.getIntent().getDisplayName();
            String fulfillmentText = queryResult.getFulfillmentText();
            Struct parameters = queryResult.getParameters();
            float intentConfidence = queryResult.getIntentDetectionConfidence();

            log.info("Dialogflow Intent 감지: {} (신뢰도: {}) - {}", intentDisplayName, intentConfidence, fulfillmentText);
            
            if (intentConfidence < CONFIDENCE_THRESHOLD && 
                !intentDisplayName.equals("Default_Welcome_Intent") && 
                !intentDisplayName.equals("Default_Fallback_Intent") &&
                !intentDisplayName.equals("Search_Anomaly_Events") &&
                !intentDisplayName.equals("Get_Storage_Info") &&
                !intentDisplayName.equals("Get_CCTV_List") &&
                !intentDisplayName.equals("Get_Anomaly_Statistics")) {
                log.warn("Intent 신뢰도 낮음: {} ({}), 임계값: {}", intentDisplayName, intentConfidence, CONFIDENCE_THRESHOLD);
                ChatbotResponse lowConfidenceResponse = new ChatbotResponse();
                lowConfidenceResponse.setReply("질문을 정확히 이해하지 못했습니다. 다시 한 번 말씀해 주시겠어요?\n예: '오늘 이상 행동 검색해줘', 'CCTV 목록 보여줘'");
                return lowConfidenceResponse;
            }

            Long currentUserId = getCurrentUserId();
            
            ChatbotResponse response = new ChatbotResponse();

            switch (intentDisplayName) {
                case "Default_Welcome_Intent":
                    response.setReply(fulfillmentText);
                    break;
                case "Search_Anomaly_Events":
                    return handleSearchAnomalyEvents(parameters, currentUserId);
                case "Get_Anomaly_Trends":
                    return handleGetAnomalyTrends(parameters, currentUserId);
                case "Get_CCTV_List":
                    return handleGetCctvList(currentUserId);
                case "Get_Storage_Info":
                    return handleGetStorageInfo(currentUserId);
                case "Get_Dashboard_Summary":
                    return handleGetDashboardSummary(parameters, currentUserId);
                case "Get_Recent_Videos":
                    return handleGetRecentVideos(parameters, currentUserId);
                case "Get_CCTV_Status":
                    return handleGetCctvStatus(parameters, currentUserId);
                case "Get_Anomaly_Details":
                    return handleGetAnomalyDetails(parameters, currentUserId);
                case "Get_User_Settings":
                    return handleGetUserSettings(currentUserId);
                case "Update_Notification_Settings":
                    return handleUpdateNotificationSettings(parameters, currentUserId);
                case "Default_Fallback_Intent":
                    response.setReply(fulfillmentText);
                    break;
                default:
                    response.setReply("죄송합니다. 이해하지 못했습니다. 다시 말씀해 주시겠어요?");
                    break;
            }
            
            log.info("챗봇 응답 생성 완료");
            return response;
        } catch (Exception e) {
            log.error("챗봇 메시지 처리 중 오류 발생", e);
            ChatbotResponse errorResponse = new ChatbotResponse();
            errorResponse.setReply("죄송합니다. 처리 중 오류가 발생했습니다. 잠시 후 다시 시도해 주세요.");
            return errorResponse;
        }
    }

    private Long getCurrentUserId() {
        Authentication authentication = SecurityContextHolder.getContext().getAuthentication();
        String email = authentication.getName();
        
        User currentUser = userRepository.findByEmail(email)
                .orElseThrow(() -> new RuntimeException("사용자를 찾을 수 없습니다: " + email));
        Long currentUserId = currentUser.getUserId();
        
        log.info("사용자 인증 완료: userId={}, email={}", currentUserId, email);
        return currentUserId;
    }

    private ChatbotResponse handleSearchAnomalyEvents(Struct parameters, Long userId) {
        log.info("수신된 모든 파라미터: {}", parameters.getFieldsMap());
        
        String cctvNameInput = parameters.getFieldsOrDefault("cctv_name", Value.newBuilder().setStringValue("").build()).getStringValue();
        if (cctvNameInput.isEmpty()) {
            cctvNameInput = parameters.getFieldsOrDefault("cctvName", Value.newBuilder().setStringValue("").build()).getStringValue();
        }
        
        String anomalyTypeInput = parameters.getFieldsOrDefault("anomaly_type", Value.newBuilder().setStringValue("").build()).getStringValue();
        if (anomalyTypeInput.isEmpty()) {
            anomalyTypeInput = parameters.getFieldsOrDefault("anomalyType", Value.newBuilder().setStringValue("").build()).getStringValue();
        }
        
        String date = parameters.getFieldsOrDefault("date", Value.newBuilder().setStringValue("").build()).getStringValue();
        String datePeriod = parameters.getFieldsOrDefault("date-period", Value.newBuilder().setStringValue("").build()).getStringValue();

        log.info("이상 행동 검색 파라미터(원본) - cctvNameInput: {}, anomalyTypeInput: {}, date: {}, datePeriod: {}", 
                 cctvNameInput, anomalyTypeInput, date, datePeriod);
        
        String cctvName = "";
        if (!cctvNameInput.isEmpty()) {
            Cctv matchedCctv = findBestMatchingCctv(cctvNameInput, userId);
            if (matchedCctv != null) {
                cctvName = matchedCctv.getCctvName();
                log.info("CCTV 매칭 성공: 입력='{}' → 매칭='{}'", cctvNameInput, cctvName);
            } else {
                log.warn("CCTV 매칭 실패: 입력='{}' (임계값 미달 또는 CCTV 없음)", cctvNameInput);
            }
        }
        
        String anomalyType = anomalyTypeInput;
        // "이상행동"이라는 입력은 모든 이상행동 유형을 검색하도록 빈 문자열로 변환
        if (anomalyType.equals("이상행동") || anomalyType.equals("이상 행동")) {
            log.info("'이상행동' 키워드 감지 - 모든 유형 검색으로 변환");
            anomalyType = "";
        }

        log.info("이상 행동 검색 파라미터(최종) - cctvName: {}, anomalyType: {}, date: {}, datePeriod: {}", 
                 cctvName, anomalyType, date, datePeriod);

        LocalDateTime startDate = null;
        LocalDateTime endDate = null;

        if (parameters.containsFields("date-time")) {
            Value dateTimeValue = parameters.getFieldsOrThrow("date-time");
            Struct dateTimeStruct = null;
            
            if (dateTimeValue.hasListValue() && dateTimeValue.getListValue().getValuesCount() > 0) {
                Value firstValue = dateTimeValue.getListValue().getValues(0);
                if (firstValue.hasStructValue()) {
                    dateTimeStruct = firstValue.getStructValue();
                }
            } else if (dateTimeValue.hasStructValue()) {
                dateTimeStruct = dateTimeValue.getStructValue();
            }
            
            if (dateTimeStruct != null) {
                String startDateStr = dateTimeStruct.getFieldsOrDefault("startDate", Value.newBuilder().setStringValue("").build()).getStringValue();
                String endDateStr = dateTimeStruct.getFieldsOrDefault("endDate", Value.newBuilder().setStringValue("").build()).getStringValue();
                
                log.info("date-time 파라미터 파싱: startDate={}, endDate={}", startDateStr, endDateStr);
                
                if (!startDateStr.isEmpty() && !endDateStr.isEmpty()) {
                    startDate = parseDialogflowDateTime(startDateStr);
                    endDate = parseDialogflowDateTime(endDateStr);
                    
                    if (startDate != null && endDate != null) {
                        endDate = endDate.withHour(23).withMinute(59).withSecond(59);
                    }
                }
            }
        } else if (!date.isEmpty()) {
            LocalDateTime[] dateRange = parseSingleDate(date);
            if (dateRange != null) {
                if (!isValidDateRange(dateRange[0], dateRange[1])) {
                    return createErrorResponse("날짜 범위가 유효하지 않습니다. 시작일은 종료일보다 이전이어야 합니다.");
                }
                startDate = dateRange[0];
                endDate = dateRange[1];
            }
        } else if (!datePeriod.isEmpty()) {
            LocalDateTime[] dateRange = parseDatePeriod(datePeriod);
            if (dateRange != null) {
                if (!isValidDateRange(dateRange[0], dateRange[1])) {
                    return createErrorResponse("날짜 범위가 유효하지 않습니다. 시작일은 종료일보다 이전이어야 합니다.");
                }
                startDate = dateRange[0];
                endDate = dateRange[1];
            }
        }
        
        if (startDate == null || endDate == null) {
            log.info("날짜 파라미터 누락 - 최근 7일로 기본값 설정");
            endDate = LocalDateTime.now();
            startDate = endDate.minusDays(7);
        }

        List<AnomalyBehavior> events = anomalyBehaviorService.searchAnomalyEvents(userId, cctvName, anomalyType, startDate, endDate);

        StringBuilder replyBuilder = new StringBuilder();
        if (events.isEmpty()) {
            replyBuilder.append("검색 조건에 맞는 이상 행동이 없습니다. ");
        } else {
            replyBuilder.append("총 ").append(events.size()).append("건의 이상 행동을 찾았습니다:\n\n");
            
            for (int i = 0; i < Math.min(events.size(), 5); i++) {
                AnomalyBehavior event = events.get(i);
                replyBuilder.append("• ").append(event.getAnomalyBehaviorType())
                        .append(" - ").append(event.getAnomalyTime().toLocalDate())
                        .append(" ");
                if (event.getAnomalyTime() != null && event.getAnomalyTime().toLocalTime() != null) {
                    String timeStr = event.getAnomalyTime().toLocalTime().toString();
                    if (timeStr.length() >= 5) {
                        replyBuilder.append(timeStr.substring(0, 5));
                    }
                }
                
                if (event.getStreamingVideo() != null && event.getStreamingVideo().getCctv() != null) {
                    replyBuilder.append(" (").append(event.getStreamingVideo().getCctv().getCctvName()).append(")");
                }
                replyBuilder.append("\n\n");
            }
            
            if (events.size() > 5) {
                replyBuilder.append("\n\n... 외 ").append(events.size() - 5).append("건 더 있습니다.");
            }
        }
        
        replyBuilder.append("\n\n검색 조건: ");
        if (!cctvName.isEmpty()) replyBuilder.append("CCTV=").append(cctvName).append(", ");
        if (!anomalyType.isEmpty()) replyBuilder.append("유형=").append(anomalyType).append(", ");
        if (startDate != null) replyBuilder.append("시작=").append(startDate.toLocalDate()).append(", ");
        if (endDate != null) replyBuilder.append("종료=").append(endDate.toLocalDate());
        
        ChatbotResponse response = new ChatbotResponse();
        response.setReply(replyBuilder.toString());
        return response;
    }

    private ChatbotResponse handleGetAnomalyTrends(Struct parameters, Long userId) {

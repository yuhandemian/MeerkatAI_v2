    private LocalDateTime[] parseSingleDate(String dateStr) {
        if (dateStr == null || dateStr.isEmpty()) {
            return null;
        }
        try {
            LocalDateTime startDate = LocalDate.parse(dateStr).atStartOfDay();
            LocalDateTime endDate = startDate.plusDays(1);
            return new LocalDateTime[]{startDate, endDate};
        } catch (DateTimeParseException e) {
            log.error("날짜 파싱 오류: {}", dateStr, e);
            return null;
        }
    }

    private LocalDateTime[] parseDatePeriod(String datePeriod) {
        if (datePeriod == null || datePeriod.isEmpty()) {
            return null;
        }
        String[] dates = datePeriod.split("/");
        if (dates.length != 2) {
            log.error("잘못된 date-period 형식: {}", datePeriod);
            return null;
        }
        try {
            LocalDateTime startDate = LocalDate.parse(dates[0]).atStartOfDay();
            LocalDateTime endDate = LocalDate.parse(dates[1]).plusDays(1).atStartOfDay();
            return new LocalDateTime[]{startDate, endDate};
        } catch (DateTimeParseException e) {
            log.error("날짜 파싱 오류: {}", datePeriod, e);
            return null;
        }
    }

    private LocalDateTime parseDialogflowDateTime(String dateTimeStr) {
        if (dateTimeStr == null || dateTimeStr.isEmpty()) {
            return null;
        }
        try {
            LocalDateTime parsedDateTime = LocalDateTime.parse(dateTimeStr.substring(0, 19));
            
            if (parsedDateTime.getYear() > LocalDateTime.now().getYear()) {
                parsedDateTime = parsedDateTime.minusYears(1);
                log.info("미래 연도 감지 - 1년 차감: {} → {}", dateTimeStr, parsedDateTime);
            }
            
            return parsedDateTime;
        } catch (Exception e) {
            log.error("Dialogflow DateTime 파싱 오류: {}", dateTimeStr, e);
            return null;
        }
    }

    private int calculateLevenshteinDistance(String s1, String s2) {
        int[][] dp = new int[s1.length() + 1][s2.length() + 1];
        
        for (int i = 0; i <= s1.length(); i++) {
            dp[i][0] = i;
        }
        for (int j = 0; j <= s2.length(); j++) {
            dp[0][j] = j;
        }
        
        for (int i = 1; i <= s1.length(); i++) {
            for (int j = 1; j <= s2.length(); j++) {
                int cost = (s1.charAt(i - 1) == s2.charAt(j - 1)) ? 0 : 1;
                dp[i][j] = Math.min(
                    Math.min(dp[i - 1][j] + 1, dp[i][j - 1] + 1),
                    dp[i - 1][j - 1] + cost
                );
            }
        }
        
        return dp[s1.length()][s2.length()];
    }
    
    private double calculateLevenshteinSimilarity(String s1, String s2) {
        if (s1 == null || s2 == null || s1.isEmpty() || s2.isEmpty()) {
            return 0.0;
        }
        int distance = calculateLevenshteinDistance(s1, s2);
        int maxLen = Math.max(s1.length(), s2.length());
        return 1.0 - ((double) distance / maxLen);
    }
    
    private Cctv findBestMatchingCctv(String userInput, Long userId) {
        if (userInput == null || userInput.trim().isEmpty()) {
            return null;
        }
        
        List<Cctv> likeResults = cctvRepository.findByUser_UserIdAndCctvNameContaining(userId, userInput);
        List<Cctv> allCctvs = cctvRepository.findByUser_UserId(userId);
        
        if (allCctvs.isEmpty()) {
            return null;
        }
        
        class CctvScore {
            Cctv cctv;
            double score;
            
            CctvScore(Cctv cctv, double score) {
                this.cctv = cctv;
                this.score = score;
            }
        }
        
        List<CctvScore> scoredCctvs = new java.util.ArrayList<>();
        
        for (Cctv cctv : allCctvs) {
            double levenshteinSimilarity = calculateLevenshteinSimilarity(userInput, cctv.getCctvName());
            boolean likeMatch = likeResults.contains(cctv);
            
            double finalScore = levenshteinSimilarity + (likeMatch ? 0.3 : 0.0);
            
            scoredCctvs.add(new CctvScore(cctv, finalScore));
            log.info("CCTV 매칭 점수: {} | Levenshtein={:.2f}, LIKE={}, 최종={:.2f}", 
                     cctv.getCctvName(), levenshteinSimilarity, likeMatch, finalScore);
        }
        
        scoredCctvs.sort((a, b) -> Double.compare(b.score, a.score));
        
        CctvScore bestMatch = scoredCctvs.get(0);
        
        final double SIMILARITY_THRESHOLD = 0.5;
        if (bestMatch.score < SIMILARITY_THRESHOLD) {
            log.warn("최고 점수 CCTV도 임계값 미달: {} (점수: {:.2f}, 임계값: {:.2f})", 
                     bestMatch.cctv.getCctvName(), bestMatch.score, SIMILARITY_THRESHOLD);
            return null;
        }
        
        log.info("최종 선택된 CCTV: {} (점수: {:.2f})", bestMatch.cctv.getCctvName(), bestMatch.score);
        return bestMatch.cctv;
    }

    private boolean isValidDateRange(LocalDateTime startDate, LocalDateTime endDate) {
        if (startDate == null || endDate == null) {
            return true;
        }
        if (startDate.isAfter(endDate)) {
            log.warn("날짜 범위 검증 실패: 시작일({})이 종료일({})보다 늦습니다.", startDate, endDate);
            return false;
        }
        LocalDateTime now = LocalDateTime.now();
        if (startDate.isAfter(now)) {
            log.warn("날짜 범위 검증 실패: 시작일({})이 현재 시간({})보다 늦습니다.", startDate, now);
            return false;
        }
        return true;
    }

    private boolean isValidDate(LocalDate date) {
        if (date == null) {
            return true;
        }
        if (date.isAfter(LocalDate.now())) {
            log.warn("날짜 검증 실패: 날짜({})가 오늘({})보다 늦습니다.", date, LocalDate.now());
            return false;
        }
        return true;
    }


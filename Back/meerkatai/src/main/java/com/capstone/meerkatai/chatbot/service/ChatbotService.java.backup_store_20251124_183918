        StringBuilder cctvListBuilder = new StringBuilder();
        cctvListBuilder.append("📹 CCTV 목록\n\n");
        cctvListBuilder.append("총 ").append(cctvListResponse.getTotalCount()).append("대의 CCTV가 등록되어 있습니다:\n\n");
        
        if (cctvListResponse.getCctvList().isEmpty()) {
            cctvListBuilder.append("등록된 CCTV가 없습니다. 새 CCTV를 추가해보세요!");
        } else {
            for (CctvListResponse.CctvInfo cctv : cctvListResponse.getCctvList()) {
                cctvListBuilder.append("• ").append(cctv.getCctvName())
                        .append(" (").append(cctv.getIpAddress()).append(")")

        String date = parameters.getFieldsOrDefault("date", Value.newBuilder().setStringValue("").build()).getStringValue();
        String datePeriod = parameters.getFieldsOrDefault("date-period", Value.newBuilder().setStringValue("").build()).getStringValue();
        String anomalyType = parameters.getFieldsOrDefault("anomalyType", Value.newBuilder().setStringValue("").build()).getStringValue();

        log.info("이상 행동 통계/트렌드 파라미터 - anomalyType: {}, date: {}, datePeriod: {}", 
                 anomalyType, date, datePeriod);

        LocalDateTime trendsStartDate = null;
        LocalDateTime trendsEndDate = null;

        if (parameters.containsFields("date-time")) {
            Value dateTimeValue = parameters.getFieldsOrThrow("date-time");
            Struct dateTimeStruct = null;
            
            if (dateTimeValue.hasListValue() && dateTimeValue.getListValue().getValuesCount() > 0) {
                Value firstValue = dateTimeValue.getListValue().getValues(0);
                if (firstValue.hasStructValue()) {
                    dateTimeStruct = firstValue.getStructValue();
                }
            } else if (dateTimeValue.hasStructValue()) {
                dateTimeStruct = dateTimeValue.getStructValue();
            }
            
            if (dateTimeStruct != null) {
                String startDateStr = dateTimeStruct.getFieldsOrDefault("startDate", Value.newBuilder().setStringValue("").build()).getStringValue();
                String endDateStr = dateTimeStruct.getFieldsOrDefault("endDate", Value.newBuilder().setStringValue("").build()).getStringValue();
                
                log.info("date-time 파라미터 파싱: startDate={}, endDate={}", startDateStr, endDateStr);
                
                if (!startDateStr.isEmpty() && !endDateStr.isEmpty()) {
                    trendsStartDate = parseDialogflowDateTime(startDateStr);
                    trendsEndDate = parseDialogflowDateTime(endDateStr);
                    
                    if (trendsStartDate != null && trendsEndDate != null) {
                        trendsEndDate = trendsEndDate.withHour(23).withMinute(59).withSecond(59);
                    }
                }
            }
        } else if (!date.isEmpty()) {
            LocalDateTime[] dateRange = parseSingleDate(date);
            if (dateRange != null) {
                if (!isValidDateRange(dateRange[0], dateRange[1])) {
                    return createErrorResponse("날짜 범위가 유효하지 않습니다. 시작일은 종료일보다 이전이어야 합니다.");
                }
                trendsStartDate = dateRange[0];
                trendsEndDate = dateRange[1];
            }
        } else if (!datePeriod.isEmpty()) {
            LocalDateTime[] dateRange = parseDatePeriod(datePeriod);
            if (dateRange != null) {
                if (!isValidDateRange(dateRange[0], dateRange[1])) {
                    return createErrorResponse("날짜 범위가 유효하지 않습니다. 시작일은 종료일보다 이전이어야 합니다.");
                }
                trendsStartDate = dateRange[0];
                trendsEndDate = dateRange[1];
            }
        }
        
        if (trendsStartDate == null || trendsEndDate == null) {
            log.info("날짜 파라미터 누락 - 최근 7일로 기본값 설정");
            trendsEndDate = LocalDateTime.now();
            trendsStartDate = trendsEndDate.minusDays(7);
        }

        if (trendsStartDate != null && trendsEndDate != null) {
            AnomalyTrendResponse trendResponse = anomalyBehaviorService.getAnomalyTrends(
                userId, anomalyType, trendsStartDate, trendsEndDate);

            StringBuilder trendsReplyBuilder = new StringBuilder();
            trendsReplyBuilder.append("📈 이상 행동 트렌드 분석 결과\n\n");
            trendsReplyBuilder.append("📅 분석 기간: ").append(trendResponse.getAnalysisPeriod()).append("\n\n");
            trendsReplyBuilder.append("📊 총 이상 행동 건수: ").append(trendResponse.getTotalCount()).append("건\n\n");

            if (trendResponse.getTotalCount() > 0) {
                trendsReplyBuilder.append("🔍 유형별 통계:\n\n");
                trendResponse.getTypeStatistics().forEach((type, count) -> {
                    String typeName = getAnomalyTypeName(type);
                    trendsReplyBuilder.append("• ").append(typeName).append(": ").append(count).append("건\n\n");
                });

                trendsReplyBuilder.append("⏰ 시간대별 통계 (상위 3개):\n\n");
                trendResponse.getHourlyStatistics().entrySet().stream()
                    .sorted(Map.Entry.<Integer, Long>comparingByValue().reversed())
                    .limit(3)
                    .forEach(entry -> {
                        trendsReplyBuilder.append("• ").append(entry.getKey()).append("시: ").append(entry.getValue()).append("건\n");
                    });

                if (!trendResponse.getCctvStatistics().isEmpty()) {
                    trendsReplyBuilder.append("\n📹 CCTV별 통계 (상위 3개):\n");
                    trendResponse.getCctvStatistics().entrySet().stream()
                        .sorted(Map.Entry.<String, Long>comparingByValue().reversed())
                        .limit(3)
                        .forEach(entry -> {
                            trendsReplyBuilder.append("• ").append(entry.getKey()).append(": ").append(entry.getValue()).append("건\n");
                        });
                }

                trendsReplyBuilder.append("\n\n").append(trendResponse.getTrendAnalysis());
            } else {
                trendsReplyBuilder.append("분석 기간 동안 이상 행동이 발생하지 않았습니다.\n");
                trendsReplyBuilder.append("상태가 양호합니다! 🎉");
            }

            ChatbotResponse response = new ChatbotResponse();
            response.setReply(trendsReplyBuilder.toString());
            return response;
        } else {
            return createErrorResponse("날짜 형식이 올바르지 않습니다. 'YYYY-MM-DD/YYYY-MM-DD' 형식으로 입력해주세요.");
        }
    }

